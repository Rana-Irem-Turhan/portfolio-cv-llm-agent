# Required when using OpenAI embeddings.
OPENAI_API_KEY=sk-your-key-here

# Optional overrides.
CV_AGENT_VECTOR_DB_DIR=./data/chroma
CV_AGENT_COLLECTION_NAME=cv_knowledge_base
CV_AGENT_EMBEDDING_PROVIDER=openai
CV_AGENT_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional Gemini embeddings. Keep real keys only in local .env or shell env.
GEMINI_API_KEY=your-gemini-key-here
CV_AGENT_GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
